  "keyFeatures": [
    "Multi-step event registration with form validation",
    "Protected admin dashboard with Google OAuth authentication",
    "Interactive event schedule and timeline",
    "Media galleries with Cloudflare CDN integration",
    "Seva (service) submission forms for community engagement",
    "Background audio system with fade controls",
    "Responsive design with mobile-first approach",
    "Atomic design component architecture",
    "Supabase backend with Row Level Security",
    "Cloudflare R2 and Images for optimized asset delivery"
  ],
  "publicApiSurface": [
    "/api/registrations - Event registration submission",
    "/api/admin/registrations - Admin data access with filtering and export",
    "/api/download - Secure file download endpoint",
    "/api/generate-upload-urls - Generate presigned R2 upload URLs",
    "getCloudflareImage() - CDN image helper",
    "getCloudflareImageMobileWp() - Mobile optimized images",
    "createClient() - Supabase client factory",
    "useAudio() - Audio playback control hook",
    "useLoading() - Global loading state hook",
    "useDeviceType() - Device detection hook"
